# OMC local state — never push
.omc/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Virtual envs
.venv/
venv/
env/

# Run artifacts — per-run predictions / metrics. The directory itself is
# tracked via outputs/.gitignore + outputs/README.md.
outputs/**
!outputs/.gitignore
!outputs/README.md

# OS / editor cruft
.DS_Store
.idea/
.vscode/
*.swp

# models
/models/

#dataset
supra-vqa
logs

# results/ is tracked (metrics.json + markdown analysis under results/metrics/
# and results/analysis/). Block accidental large binary/intermediate dumps.
results/**/*.pkl
results/**/*.parquet
results/**/*.ckpt
results/**/*.safetensors
results/.ipynb_checkpoints/
# auto-generated per-submission launchers from submit_eval.sh / submit_extract.sh
scripts/crc/_generated/
