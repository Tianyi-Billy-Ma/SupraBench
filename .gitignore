paper-overleaf/
scripts/overleaf/
docs/
data/molecular-pretrain/

# Local paper-generation and audit helpers from active drafting sessions.
tools/render_dataset_stats_figure.py
tools/render_overview_figure.py
tools/resolve_cite_placeholders.py
