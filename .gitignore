# OMC local state — never push
.omc/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Virtual envs
.venv/
venv/
env/

# Run artifacts — per-run predictions / metrics. The directory itself is
# tracked via outputs/.gitignore + outputs/README.md.
outputs/**
!outputs/.gitignore
!outputs/README.md

# OS / editor cruft
.DS_Store
.idea/
.vscode/
*.swp

# models
/models/

#dataset
supra-vqa
logs

# results/ is tracked (metrics.json + markdown analysis under results/metrics/
# and results/analysis/). Block accidental large binary/intermediate dumps.
results/**/*.pkl
results/**/*.parquet
results/**/*.ckpt
results/**/*.safetensors
results/.ipynb_checkpoints/
results/task1_task2_results.zip
results/analysis/*.md
results/analysis/dataset_stats.json
results/metrics/task1_base_llama3.1-8b-supra-v2-lora/
results/metrics/task1_base_qwen3.5-9b-supra-v2-lora/
results/metrics/task2_base_qwen3.5-9b-supra-v2-lora/
results/metrics/task3_base_llama3.1-8b-supra-v2-lora/
results/metrics/task3_base_qwen3.5-9b-supra-v2-lora/
results/metrics/task7_base_qwen3.5-9b-supra-v2-lora/

