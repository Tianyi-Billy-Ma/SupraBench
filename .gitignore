# OMC local state — never push
.omc/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Virtual envs
.venv/
venv/
env/

# Run artifacts — per-run predictions / metrics. The directory itself is
# tracked via outputs/.gitignore + outputs/README.md.
outputs/**
!outputs/.gitignore
!outputs/README.md

# Secrets — real .env is local-only (.env.example is the template).
.env

# OS / editor cruft
.DS_Store
.idea/
.vscode/
*.swp

# Local model weights (downloaded checkpoints) — top-level only, so this
# does not accidentally ignore configs/models/ or src/models/.
/models/

# Local dataset checkout + run artifacts (top-level only).
/supra-vqa/
/results/
/logs/